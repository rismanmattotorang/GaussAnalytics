# GaussAnalytics configuration (copy to .env and adjust).
# All variables are optional; defaults are shown.

# --- HTTP server ---
GAUSS_HOST=127.0.0.1
GAUSS_PORT=3000
GAUSS_STATIC_DIR=frontend/dist
# Query-result cache TTL (seconds); 0 disables caching.
GAUSS_CACHE_TTL_SECS=0
# Background scheduler tick period (seconds) for schema refresh/alerts; 0 disables.
GAUSS_SCHEDULER_PERIOD_SECS=60

# --- Application metadata database (used from Phase 2) ---
GAUSS_DATABASE_URL=sqlite://data/gauss.db

# --- Security ---
GAUSS_SESSION_TTL_SECS=1209600   # 14 days
# Require a valid principal (session or API key) on all API routes except
# /api/health, /api/version, /api/auth/login. Default false for local dev.
GAUSS_REQUIRE_AUTH=false
# Static service API keys (comma-separated). A request bearing one (X-API-Key
# header or Authorization: Bearer) authenticates as a service administrator.
# GAUSS_API_KEYS=key-one,key-two
# HMAC secret for signed embedding tokens. Empty disables embedding.
# GAUSS_EMBEDDING_SECRET=change-me-to-a-long-random-string

# --- In-house NL2SQL engine ---
# Translation runs in-process against a configured LLM provider; there is no
# external NL2SQL service. `API_KEY` (when needed) is the LLM provider's own key.
GAUSS_NL2SQL_ENABLED=false
# Provider: mock | openai | openrouter | litellm | vllm | bedrock | anthropic | ollama | gemini
#   - openrouter/litellm/vllm/bedrock are OpenAI-compatible (litellm/vllm/bedrock
#     need GAUSS_NL2SQL_BASE_URL; bedrock is reached via a LiteLLM/OpenAI gateway).
GAUSS_NL2SQL_PROVIDER=mock
# Model identifier passed to the provider (e.g. gpt-4o-mini, claude-..., llama3).
# GAUSS_NL2SQL_MODEL=
# Provider API key (not required for mock/ollama).
# GAUSS_NL2SQL_API_KEY=
# OpenAI-compatible endpoint (required for litellm/vllm; the gateway URL for bedrock).
# GAUSS_NL2SQL_BASE_URL=
GAUSS_NL2SQL_TIMEOUT_MS=30000

# --- Conversational chat clients (gauss-chat / gauss-chat-tui) ---
# These are standalone agent binaries; flags override the env vars below.
# Provider: mock | ollama | openai | anthropic | gemini | vllm
GAUSS_CHAT_LLM=mock
# GAUSS_CHAT_MODEL=gpt-4o-mini
# GAUSS_CHAT_LLM_BASE_URL=http://localhost:11434
# SQLite database (seeded with demo data if absent) and HTTP port for the web UI.
GAUSS_CHAT_DB=gauss_demo.db
GAUSS_CHAT_PORT=8000
# Sandbox dir for query CSVs/charts, optional semantic model, optional audit log.
GAUSS_CHAT_DATA_DIR=./gauss_data
# GAUSS_CHAT_SEMANTIC_MODEL=model.yaml
# GAUSS_CHAT_AUDIT_LOG=audit.jsonl
# Provider keys (standard names): OPENAI_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY, VLLM_API_KEY

# --- Embedded notebooks: local Jupyter kernel gateway (post-1.0, off by default) ---
# Notebook code runs on YOUR local Python + Jupyter Server; GaussAnalytics connects to it.
# Start one with:  jupyter server --IdentityProvider.token=<token>
GAUSS_JUPYTER_ENABLED=false
GAUSS_JUPYTER_URL=http://127.0.0.1:8888
# GAUSS_JUPYTER_TOKEN=<jupyter server token>

# --- Gaussian MCP Gateway integration ---
GAUSS_MCP_ENABLED=false
GAUSS_MCP_BASE_URL=http://localhost:8848
GAUSS_MCP_TIMEOUT_MS=30000

# --- Admin TUI (gaussctl admin) ---
# Server the console reads from, and an admin bearer token for the Users view.
GAUSS_API_URL=http://127.0.0.1:3000
# GAUSS_API_TOKEN=<paste a session token from POST /api/auth/login>

# --- First-run administrator bootstrap (gaussctl serve) ---
# GAUSS_ADMIN_EMAIL=admin@example.com
# GAUSS_ADMIN_PASSWORD=change-me-please

# --- Logging ---
RUST_LOG=info
