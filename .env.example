# GaussAnalytics configuration (copy to .env and adjust).
# All variables are optional; defaults are shown.

# --- HTTP server ---
GAUSS_HOST=127.0.0.1
GAUSS_PORT=3000
GAUSS_STATIC_DIR=frontend/dist

# --- Application metadata database (used from Phase 2) ---
GAUSS_DATABASE_URL=sqlite://data/gauss.db

# --- Security ---
GAUSS_SESSION_TTL_SECS=1209600   # 14 days

# --- Gaussian NL2SQL integration ---
GAUSS_NL2SQL_ENABLED=false
GAUSS_NL2SQL_BASE_URL=http://localhost:8849
GAUSS_NL2SQL_TIMEOUT_MS=30000

# --- Gaussian MCP Gateway integration ---
GAUSS_MCP_ENABLED=false
GAUSS_MCP_BASE_URL=http://localhost:8848
GAUSS_MCP_TIMEOUT_MS=30000

# --- Logging ---
RUST_LOG=info
